{
  "name": "eric_icons",
  "version": "1.0.0",
  "description": "Icon font kit built from SVGs (Font Awesome–style CSS + installable fonts).",
  "scripts": {
    "build": "node -e \"require('fs').mkdirSync('dist',{recursive:true})\" && fantasticon",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "readme:icons": "node scripts/update-readme-icons.js",
    "postinstall": "patch-package"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "fantasticon": "^4.1.0",
    "patch-package": "^8.0.1"
  }
}
